#include <stdio.h>\
int main() 
{
    int n, a = 0, b = 1, c, i = 1;
    printf("Enter number of terms: ");
    scanf("%d", &n);
    printf("Even Fibonacci numbers:\n");
    while (i <= n) {
        if (a % 2 == 0)
            printf("%d ", a);
        c = a + b;
        a = b;
        b = c;
        i++;
    }
    a = 0;
    b = 1;
    i = 1;
    printf("\nOdd Fibonacci numbers:\n");
    while (i <= n) {
        if (a % 2 != 0)
            printf("%d ", a);
        c = a + b;
        a = b;
        b = c;
        i++;
    }
    return 0;
}
