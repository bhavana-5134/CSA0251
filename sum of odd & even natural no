#include <stdio.h>
int main() 
{
    int n, i = 1, even_sum = 0, odd_sum = 0;
    printf("Enter n: ");
    scanf("%d", &n);
    while (i <= n)
    {
        if (i % 2 == 0)
            even_sum = even_sum + i;
        else
            odd_sum = odd_sum + i;

        i++;
    }
    printf("Sum of even numbers = %d\n", even_sum);
    printf("Sum of odd numbers = %d", odd_sum);
    return 0;
}
