#include <stdio.h>
int main()
{
    int age;
    printf("Enter your age: ");
    scanf("%d", &age);
    if (age >= 18)
{
        printf("You are eligible for voting");
    }
else
{
        printf("Not eligible for voting\n");
        printf("You can vote after %d years", 18 - age);
    }
    return 0;
}
